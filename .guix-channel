;; alpha-agent — a consumer channel defining the user's personal agent,
;; bound to a PKS (Denote/org) durable-memory backend.
;;
;; Modules live at the repository root (module (alpha-agent …) -> alpha-agent/…),
;; matching local development with `-L ~/src/alpha-agent`.
;;
;; Dependencies are aspirational until guix-agentic is published (follow-up #4).
;; For local dev, compose with:
;;   -L ~/src/guix-agentic -L ~/src/alpha-agent -L ~/.dotfiles
;; The entelequia load path supplies the `denotecli` package (the mechanism the
;; PKS backend calls); it is not declared a channel dependency here because it is
;; the user's personal dotfiles config, not a published channel.
(channel
 (version 0)
 (dependencies
  (channel
   (name guix-agentic)
   (url "https://github.com/OUH-MESHLab/guix-agentic")
   (branch "main"))
  ;; forager.scm / manifests/forager.scm import (guix-codegraph packages
  ;; codegraph); the channel build resolves modules only through declared
  ;; dependencies, so this must be here (a -L flag masked the gap in local dev).
  (channel
   (name guix-codegraph)
   (url "https://github.com/OUH-MESHLab/guix-codegraph")
   (branch "main"))
  ;; mcp.scm imports (guix-openclaw packages node-openclaw-deps) for the MCP SDK
  ;; + zod used to bundle pi-mcp-extension; the channel build resolves modules
  ;; only through declared deps (a -L flag masked the gap in local dev).
  (channel
   (name guix-openclaw)
   (url "https://github.com/OUH-MESHLab/guix-openclaw")
   (branch "main"))
  (channel
   (name nonguix)
   (url "https://gitlab.com/nonguix/nonguix")
   (branch "master"))))
